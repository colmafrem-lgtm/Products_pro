# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=investment_db

# JWT Secret (change this to a long random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Admin JWT (separate secret for admin)
ADMIN_JWT_SECRET=your_admin_secret_key_change_this_too
ADMIN_JWT_EXPIRES_IN=1d
